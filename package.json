{
  "name": "stratosort-frontend",
  "version": "0.1.0",
  "description": "AI-powered file organization desktop application - Frontend",
  "author": "StratoSort Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iLevyTate/StratoSortRust.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:1431": "vite preview --port 1431",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --config vitest.ci.config.ts",
    "test:integration": "vitest run src/tests/integration/*.test.ts",
    "test:performance": "vitest run src/tests/performance/*.test.ts",
    "test:security": "vitest run src/tests/security/*.test.ts",
    "test:quick": "vitest run --config vitest.quick.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "dev:tauri": "npm run tauri:dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.40.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/typography": "^0.5.10",
    "@tauri-apps/api": ">=2.0.0-beta.0",
    "@tauri-apps/cli": ">=2.0.0-beta.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/svelte": "^4.0.5",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.16",
    "happy-dom": "^18.0.1",
    "msw": "^2.0.11",
    "postcss": "^8.4.32",
    "svelte": "^4.2.7",
    "svelte-check": "^3.6.0",
    "tailwindcss": "^3.3.6",
    "taurpc": "^1.8.1",
    "typescript": "^5.0.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.5.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "bits-ui": "^0.19.0",
    "clsx": "^2.1.0",
    "lucide-svelte": "^0.263.0",
    "mode-watcher": "^0.2.0",
    "svelte-sonner": "^0.3.0",
    "tailwind-merge": "^2.2.0",
    "tailwind-variants": "^0.1.18",
    "zod": "^3.22.4"
  }
}
