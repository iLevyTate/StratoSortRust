{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StratoSort",
  "version": "0.1.0",
  "identifier": "com.stratosort.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1431"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1NURDNEUzNEJGQTlCQzEKUldUQm0vcEw0OFJkdFRweXRkbm9PTXRxMWZJS1RJUHlVSGcxVlVpb2ViN09Ob042VUZOOUpKcDYK"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "StratoSort - AI File Organization",
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "visible": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: tauri:; script-src 'self' http://localhost:* https://localhost:*; style-src 'self' 'unsafe-inline' http://localhost:* https://localhost:*; img-src 'self' asset: data: blob: tauri: http://localhost:* https://localhost:*; font-src 'self' data: http://localhost:* https://localhost:*; connect-src 'self' ipc: http://localhost:* https://localhost:* ws://localhost:* wss://localhost:* http://127.0.0.1:11434 https://127.0.0.1:11434 http://127.0.0.1:* https://127.0.0.1:*; media-src 'self' blob: data:; worker-src 'self' blob:; child-src 'none'; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; embed-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/stratosort/**",
          "$RESOURCE/**"
        ]
      },
      "freezePrototype": true
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "© 2024 StratoSort",
    "shortDescription": "AI-powered file organization",
    "longDescription": "StratoSort uses local AI to intelligently organize your files with privacy-first design.",
    "homepage": "https://stratosort.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": null,
      "nsis": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    }
  }
}