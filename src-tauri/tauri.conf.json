{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StratoSort",
  "version": "0.1.0",
  "identifier": "com.stratosort.app",
  "build": {
    "beforeDevCommand": null,
    "beforeBuildCommand": null,
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "StratoSort - AI File Organization",
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset: tauri: http://localhost:*",
        "script-src": "'self' 'unsafe-eval' http://localhost:*",
        "style-src": "'self' 'unsafe-inline' http://localhost:*",
        "img-src": "'self' asset: data: blob: tauri: http://localhost:*",
        "font-src": "'self' data: http://localhost:*",
        "connect-src": "'self' ipc: http://localhost:* ws://localhost:* http://127.0.0.1:11434",
        "frame-src": "'none'",
        "object-src": "'none'",
        "base-uri": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/stratosort/**",
          "$RESOURCE/**"
        ]
      },
      "freezePrototype": true
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "© 2024 StratoSort",
    "shortDescription": "AI-powered file organization",
    "longDescription": "StratoSort uses local AI to intelligently organize your files with privacy-first design.",
    "homepage": "https://stratosort.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": null,
      "nsis": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    }
  }
}