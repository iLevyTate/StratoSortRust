{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for StratoSort",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-create",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "core:path:default",
    "os:default",
    "process:default",
    "http:default",
    "core:menu:default",
    "core:tray:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/stratosort",
        "$APPDATA/stratosort/**",
        "$RESOURCE",
        "$RESOURCE/**",
        "$DOWNLOAD/StratoSort",
        "$DOWNLOAD/StratoSort/**",
        "$DOCUMENT/StratoSort",
        "$DOCUMENT/StratoSort/**",
        "$PICTURE/StratoSort",
        "$PICTURE/StratoSort/**",
        "$DESKTOP/StratoSort",
        "$DESKTOP/StratoSort/**"
      ],
      "deny": [
        "$HOME/.ssh/**",
        "$HOME/.gnupg/**",
        "$HOME/.config/**",
        "$HOME/.aws/**",
        "$HOME/.azure/**",
        "$HOME/.kube/**",
        "$HOME/.docker/**",
        "$APPDATA/Microsoft/Credentials/**",
        "$LOCALAPPDATA/Google/Chrome/User Data/**",
        "$LOCALAPPDATA/Mozilla/Firefox/**",
        "$HOME/.*"
      ]
    },
    "notification:default",
    "global-shortcut:default",
    "clipboard-manager:default",
    "store:default",
    "window-state:default",
    "positioner:default"
  ]
}