# StratoRust Environment Configuration
# This file overrides values in config.json

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# File Settings
FILE_WATCH_ENABLED=true
MAX_FILE_SIZE=104857600  # 100MB in bytes

# Performance Settings
MAX_CONCURRENT_ANALYSIS=4
MAX_CONCURRENT_OPERATIONS=10
CACHE_SIZE_MB=100
ENABLE_GPU_ACCELERATION=false

# UI Settings
THEME=dark
LANGUAGE=en
SHOW_NOTIFICATIONS=true
NOTIFICATION_DURATION_MS=5000

# Privacy Settings
ENABLE_TELEMETRY=false
ENABLE_CRASH_REPORTS=false
ENABLE_ANALYTICS=false

# Behavior Settings
CONFIRM_BEFORE_DELETE=true
CONFIRM_BEFORE_MOVE=false

# Advanced Settings
DEBUG_MODE=false
HISTORY_RETENTION_DAYS=30
UNDO_HISTORY_SIZE=50

# File Extensions to Ignore (comma-separated)
FILE_EXTENSIONS_IGNORE=.tmp,.temp,.cache,.log